<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Postify — Create Post</title>
</head>
<body>

<%- include('navbar') %>

<div class="page">
    <div class="page-header">
        <h1 class="page-title">Create a <span>Post</span></h1>
        <a href="/posts" class="btn btn-ghost btn-sm">← Back</a>
    </div>

    <% if (typeof query !== 'undefined' && query.error === 'empty') { %>
        <div class="alert alert-danger">⚠️ Username and content cannot be empty.</div>
    <% } %>

    <div class="form-card">
        <form action="/posts" method="post">
            <div class="form-group">
                <label class="form-label" for="username">Username</label>
                <input
                    class="form-control"
                    id="username"
                    type="text"
                    name="username"
                    placeholder="e.g. Apoorv"
                    maxlength="32"
                    required
                />
            </div>
            <div class="form-group">
                <label class="form-label" for="content">What's on your mind?</label>
                <textarea
                    class="form-control"
                    id="content"
                    name="content"
                    placeholder="Share your thoughts..."
                    maxlength="500"
                    required
                ></textarea>
            </div>
            <div class="form-actions">
                <button class="btn btn-primary" type="submit">✦ Post</button>
                <a href="/posts" class="btn btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>

</body>
</html>