<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Postify — Page Not Found</title>
</head>
<body>

<%- include('navbar') %>

<div class="page">
    <div class="not-found">
        <div class="code">404</div>
        <h2>Page not found</h2>
        <p>The post you're looking for doesn't exist or was deleted.</p>
        <a href="/posts" class="btn btn-primary">← Back to Posts</a>
    </div>
</div>

</body>
</html>